# Zoom Chat Aggregator Configuration
# ===================================
# Copy this file to .env and fill in your values

# Zoom App Credentials (from Zoom Marketplace App settings)
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
ZOOM_WEBHOOK_SECRET_TOKEN=your_webhook_secret_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Recall.ai (preferred chat-capture path — see docs/CHAT-CAPTURE-ARCHITECTURE.md)
# When RECALL_API_KEY and PUBLIC_WEBHOOK_URL are both set, the server
# routes /api/meetings/connect through Recall instead of the legacy RTMS
# manager (which currently only runs in mock mode).
RECALL_API_KEY=
RECALL_API_BASE=https://us-east-1.recall.ai/api/v1
# PUBLIC_WEBHOOK_URL is the public HTTPS base URL where Recall can reach
# our webhook — Recall will POST chat events to {PUBLIC_WEBHOOK_URL}/webhook/recall/chat.
# In production this is the Railway URL; for local testing use ngrok.
PUBLIC_WEBHOOK_URL=
# Workspace signing secret from Recall dashboard (Developers → API Keys &
# Secrets → Create Workspace Secret). Format: "whsec_<base64>".
# If unset, /webhook/recall/chat accepts requests without verification
# and logs a warning on every hit.
RECALL_WEBHOOK_SECRET=whsec_replace_with_recall_workspace_secret

# ============================================
# AUTH / MONETIZATION (see docs/MONETIZATION-PLAN.md)
# ============================================

# Public app URL used in transactional emails (verify, password reset,
# invite links). In production this is the custom domain or Railway URL.
# Locally, http://localhost:5173 (Vite dev) or http://localhost:3001.
APP_URL=http://localhost:5173

# Resend API key for transactional emails (signup verification, password
# reset, team invitations). Get from https://resend.com/api-keys after
# verifying the sending domain.
# If unset, emails are LOGGED TO CONSOLE instead of sent — useful for
# local dev and for confirming auth works before Resend is wired up.
RESEND_API_KEY=

# Verified sender address (Resend → Domains → must be verified with
# SPF/DKIM DNS records before send works). noreply@ prevents inbound
# reply confusion.
EMAIL_FROM=noreply@zoomchat.ryteproductions.com

# Session cookie secret — used to sign/HMAC session cookies. Generate
# with: openssl rand -base64 48
# Must be set in production. Locally, defaults to a dev-only constant
# (insecure — never use the default outside local dev).
SESSION_SECRET=
